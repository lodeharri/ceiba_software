{
  "name": "mercadoexpress",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Inventory management system for a retail chain. Monorepo root.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.11"
    }
  },
  "scripts": {
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "pnpm -r --workspace-concurrency=1 test:watch",
    "test:e2e": "playwright test",
    "type-check": "pnpm -r --workspace-concurrency=1 exec tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm -r build",
    "db:migrate": "tsx scripts/db.ts migrate",
    "db:seed": "tsx scripts/db.ts seed",
    "bootstrap:secrets": "tsx scripts/bootstrap-secrets.ts",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:api": "tsx scripts/dev-server.ts",
    "dev:web": "pnpm --filter frontend dev",
    "dev:up": "docker compose --env-file .env.dev -f docker-compose.dev.yml up -d",
    "dev:down": "docker compose --env-file .env.dev -f docker-compose.dev.yml down",
    "dev:rebuild": "docker compose --env-file .env.dev -f docker-compose.dev.yml build --no-cache",
    "dev:reset": "docker compose --env-file .env.dev -f docker-compose.dev.yml down -v",
    "dev": "pnpm env:bootstrap && concurrently -k -n api,web -c green,magenta 'pnpm dev:api' 'pnpm dev:web'",
    "setup": "tsx scripts/setup.ts",
    "env:bootstrap": "tsx scripts/ensure-env.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aws-sdk/client-ssm": "^3.1084.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@mercadoexpress/infra": "workspace:*",
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.1",
    "eslint": "^9.10.0",
    "eslint-plugin-boundaries": "^4.2.2",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vue": "^9.28.0",
    "globals": "^15.9.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.1"
  }
}
