# =============================================================================
# MercadoExpress Local Development Environment
# =============================================================================
# Copy this file to .env.dev (which is gitignored) and customize as needed.
# All values here are DEFAULTS — the dev can override any value in .env.dev.local
# or directly in .env.dev (also gitignored).
#
# The dev stack is a single postgres container started via pnpm dev:up.
# The frontend runs natively via pnpm dev:web (Vite dev server on :5174).
# The API runs natively via pnpm dev:api (tsx --watch on :3001).
# See docs/LOCAL-DEV.md for the full setup flow.
# =============================================================================

# ----- Project -----
COMPOSE_PROJECT_NAME=ceiba

# ----- PostgreSQL -----
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_CONTAINER_NAME=ceiba-postgres
POSTGRES_USER=ceiba
POSTGRES_PASSWORD=ceiba_dev
POSTGRES_DB=mercadoexpress
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=ceiba_postgres_data
POSTGRES_HEALTHCHECK_RETRIES=30

# ----- AWS / SDK -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ----- Stage -----
STAGE=dev

# ----- Database URL (used by backend and migrations-lambda) -----
DATABASE_URL=postgresql://ceiba:ceiba_dev@localhost:5432/mercadoexpress

# ----- Secrets (dev only - DO NOT use these values in prod) -----
JWT_SECRET=dev-secret-change-me-in-prod-32chars-min
JWT_SECRET_PREVIOUS=

# ----- Frontend (Vite dev server runs on the host; no docker container) -----
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3001/api/v1

# ----- Network -----
LOCAL_DEV_NETWORK_NAME=ceiba_local_dev

# ----- Healthcheck defaults -----
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s

# ----- Admin Bootstrap (CDK SSM injection for dev stage) -----
# ADMIN_USERNAME and ADMIN_EMAIL are hardcoded literals in
# packages/infra/src/constructs/migrations.ts (CDK construct env).
# ADMIN_PASSWORD is auto-generated server-side via Secrets Manager
# generateSecretString - the value below is used ONLY for local docker
# development and is NEVER injected into the deployed stack.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@mercadoexpress.local
# IMPORTANT: replace this with a strong password before first pnpm setup.
# The AWS deploy path auto-generates ADMIN_PASSWORD via Secrets Manager
# generateSecretString - this value is used ONLY for local docker development.
ADMIN_PASSWORD="<replace-with-strong-password>"
