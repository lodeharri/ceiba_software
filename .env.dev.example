# =============================================================================
# MercadoExpress Local Development Environment
# =============================================================================
# Copy this file to .env.dev (which is gitignored) and customize as needed.
# All values here are DEFAULTS — the dev can override any value in .env.dev.local
# or directly in .env.dev (also gitignored).
# =============================================================================

# ----- Project -----
COMPOSE_PROJECT_NAME=ceiba

# ----- PostgreSQL -----
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_CONTAINER_NAME=ceiba-postgres
POSTGRES_USER=ceiba
POSTGRES_PASSWORD=ceiba_dev
POSTGRES_DB=mercadoexpress
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=ceiba_postgres_data
POSTGRES_HEALTHCHECK_RETRIES=30

# ----- LocalStack -----
LOCALSTACK_IMAGE=localstack/localstack:3.4
LOCALSTACK_CONTAINER_NAME=ceiba-localstack
LOCALSTACK_HOST=localstack
LOCALSTACK_BIND_HOST=127.0.0.1
LOCALSTACK_PORT=4566
LOCALSTACK_VOLUME_NAME=ceiba_localstack_data
LOCALSTACK_DEBUG=0
LOCALSTACK_PERSISTENCE=1
LOCALSTACK_LAMBDA_REMOVE_CONTAINERS=true
LOCALSTACK_SERVICES=lambda,apigateway,secretsmanager,ssm,iam,cloudformation,sts
LOCALSTACK_HEALTHCHECK_INTERVAL=10s
LOCALSTACK_HEALTHCHECK_RETRIES=30

# ----- AWS / CDK -----
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ----- Stage -----
STAGE=localstack

# ----- Database URL (used by backend and migrations-lambda) -----
DATABASE_URL=postgresql://ceiba:ceiba_dev@localhost:5432/mercadoexpress

# ----- Secrets (dev only — DO NOT use these values in prod) -----
JWT_SECRET=dev-secret-change-me-in-prod-32chars-min
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_dev_password_change_me
ADMIN_EMAIL=admin@ceiba.local

# ----- Deployer -----
DEPLOYER_CONTAINER_NAME=ceiba-deployer
DEPLOYER_HEALTHCHECK_RETRIES=60

# ----- Frontend -----
FRONTEND_IMAGE=node:20-alpine
FRONTEND_CONTAINER_NAME=ceiba-frontend
FRONTEND_PORT=5173
FRONTEND_HEALTH_HOST=localhost
FRONTEND_HEALTHCHECK_RETRIES=60
VITE_HOST=0.0.0.0
VITE_API_BASE_URL=http://localhost:4566
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_PACKAGE_NODE_MODULES_VOLUME_NAME=ceiba_frontend_node_modules
FRONTEND_ROOT_NODE_MODULES_VOLUME_NAME=ceiba_root_node_modules

# ----- Shared between deployer and frontend -----
SHARED_DATA_DIR=./.docker-shared
SHARED_DATA_VOLUME_NAME=ceiba_shared_data
API_URL_FILE=${SHARED_DATA_DIR}/.api-url
CDK_OUTPUTS_FILE=${SHARED_DATA_DIR}/cdk-outputs.json
API_URL_WAIT_TIMEOUT_SECONDS=300

# ----- API Gateway (parsed from CDK outputs) -----
API_GATEWAY_HOST_EXTERNAL=localhost
API_GATEWAY_PORT=${LOCALSTACK_PORT}

# ----- Network -----
LOCAL_DEV_NETWORK_NAME=ceiba_local_dev

# ----- Healthcheck defaults -----
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
