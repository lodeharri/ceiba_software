# Backend package env vars. Inherits DATABASE_URL / JWT_SECRET / ADMIN_* from
# the root .env (the root file is the source of truth). Variables unique to
# the backend live below.

# Rate limiting (US-1: 5 failures / 15 min lockout per (ip, username)).
AUTH_RATE_LIMIT_FAILURES=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900

# JWT (read from env by packages/backend/src/shared/jwt-middleware.ts).
# The dual-secret rotation logic reads JWT_SECRET, JWT_SECRET_PREVIOUS,
# JWT_OVERLAP_SECONDS from the parent process env.
JWT_SECRET=replace-me-with-64-hex-chars
JWT_SECRET_PREVIOUS=
JWT_OVERLAP_SECONDS=900

# Database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mercadoexpress

# Logger.
LOG_LEVEL=info

# AI adapter selection (one of: ollama | groq | openai).
AI_ADAPTER=ollama
OLLAMA_HOST=http://localhost:11434
GROQ_API_KEY=
OPENAI_API_KEY=

# Admin seed (consumed by packages/backend/prisma/seed.ts in PR 1).
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@mercadoexpress.local
ADMIN_PASSWORD=change-me-on-first-deploy

# Trusted proxy depth (RISK-W03).
TRUSTED_PROXY_DEPTH=0
