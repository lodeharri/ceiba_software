// Prisma schema for the MercadoExpress MVP (PR 2a + PR 2b, design.md §4).
//
// Tables scoped to PR 2a:
//   - users                  (auth BC)
//   - categories             (categories BC, D2 lookup)
//   - products               (products BC)
//   - login_attempts         (auth BC — RISK-003 Postgres rate limiter)
//   - idempotency_keys       (shared — RISK-W05)
//
// Tables added in PR 2b:
//   - stock_movements        (inventory BC — append-only per BR-6)
//   - alerts                 (alerts BC — BR-4 partial unique index)
//
// Tables deferred to PR 2c: purchase_orders.
// They will be appended via additive migrations (proposal §11.3 rollback contract).

// ────────────────────────────────────────────────────────────────
// PR 2c — Orders BC
// ────────────────────────────────────────────────────────────────

model PurchaseOrder {
id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
productId       String     @map("product_id") @db.Uuid
quantity        Int
status          OrderStatus @default(PENDIENTE)
supplierSnapshot String    @map("supplier_snapshot") @db.VarChar(120)
fromAlertId     String?    @map("from_alert_id") @db.Uuid
reason          String?    @db.VarChar(500)
createdBy       String     @map("created_by") @db.Uuid
receivedAt      DateTime?  @map("received_at") @db.Timestamptz(6)
createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)

// No Prisma relation to Product — cross-BC FKs are forbidden per orders/spec.md.
// The productId is a value reference; referential integrity is validated in application layer.

@@index([productId, createdAt(sort: Desc)])
@@index([status, createdAt(sort: Desc)])
@@map("purchase_orders")
}

generator client {
  provider = "prisma-client-js"
  // pnpm does not link .prisma output to node_modules by default; explicit
  // output path ensures @prisma/client/default.js can resolve .prisma/client/default.
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
}

enum MovementType {
  ENTRADA
  SALIDA
}

enum AlertStatus {
  ACTIVA
  RESUELTA
}

enum OrderStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  RECIBIDA
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(admin)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([username])
  @@map("users")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  products Product[]

  @@map("categories")
}

model Product {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku        String   @unique
  name       String
  categoryId String   @map("category_id") @db.Uuid
  price      Decimal  @db.Decimal(12, 0)
  stock      Int      @default(0)
  stockMin   Int      @map("stock_min")
  supplier   String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([supplier])
  @@index([stock])
  @@map("products")
}

model LoginAttempt {
  id          BigInt   @id @default(autoincrement())
  ip          String   @db.Inet
  username    String
  success     Boolean
  attemptedAt DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)

  @@index([ip, username, attemptedAt(sort: Desc)], map: "login_attempts_ip_username_failure_idx")
  @@map("login_attempts")
}

model IdempotencyKey {
  key            String   @id
  userId         String   @map("user_id") @db.Uuid
  requestHash    String   @map("request_hash")
  responseStatus Int      @map("response_status")
  responseBody   Json     @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@map("idempotency_keys")
}

// ────────────────────────────────────────────────────────────────
// PR 2b — Inventory BC + Alerts BC
// ────────────────────────────────────────────────────────────────

model StockMovement {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String       @map("product_id") @db.Uuid
  type      MovementType
  quantity  Int
  reason    String       @db.VarChar(280)
  userId    String       @map("user_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  // No Prisma relation to Product — the productId is a value reference (D1).
  // Cross-BC FKs are forbidden per inventory/spec.md.

  @@index([productId, createdAt(sort: Desc)])
  @@map("stock_movements")
}

model Alert {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String      @map("product_id") @db.Uuid
  type        String      @default("STOCK_BAJO")
  status      AlertStatus @default(ACTIVA)
  resolvedAt  DateTime?   @map("resolved_at") @db.Timestamptz(6)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  // BR-4: at most one ACTIVA alert per productId. Partial unique index.
  // NOTE: the partial unique index WHERE status = 'ACTIVA' is added via
  // a raw migration (Prisma schema does not support WHERE on @@unique).
  @@index([status, createdAt(sort: Desc)])
  @@index([productId])
  @@map("alerts")
}
