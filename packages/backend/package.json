{
  "name": "@mercadoexpress/backend",
  "version": "0.0.0",
  "private": true,
  "description": "Lambda handlers for the MercadoExpress backend (no Express/Fastify/NestJS).",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vitest run --watch",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^9.1.0",
    "@aws-sdk/client-ssm": "^3.1090.0",
    "@mercadoexpress/shared": "workspace:*",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jose": "^5.9.2",
    "pg": "^8.22.0",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "pg-mem": "^3.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
