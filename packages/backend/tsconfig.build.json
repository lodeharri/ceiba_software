{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@mercadoexpress/shared": ["../shared/dist/index.d.ts"],
      "@mercadoexpress/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test", "**/*.test.ts"],
  "references": [{ "path": "../shared" }]
}
