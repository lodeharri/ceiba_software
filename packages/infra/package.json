{
  "name": "@mercadoexpress/infra",
  "version": "0.0.0",
  "private": true,
  "description": "AWS CDK app for MercadoExpress (stacks, constructs).",
  "bin": {
    "mercadoexpress-infra": "dist/app.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "synth": "cdk synth --all --no-color",
    "synth:dev": "cdk synth -c stage=dev --no-color",
    "deploy:dev": "cdk deploy -c stage=dev --require-approval never"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.155.0",
    "constructs": "^10.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "aws-cdk": "^2.155.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
