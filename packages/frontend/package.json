{
  "name": "@mercadoexpress/frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Vue 3 SPA for MercadoExpress (Vite + Tailwind + Atomic Design + Pinia + i18n).",
  "type": "module",
  "scripts": {
    "build": "vite build --mode production",
    "dev": "vite",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@mercadoexpress/shared": "workspace:*",
    "ofetch": "^1.4.0",
    "pinia": "^2.2.2",
    "vue": "^3.5.0",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.6.2",
    "vite": "^5.4.4",
    "vitest": "^2.1.1",
    "vue-tsc": "^2.1.4"
  }
