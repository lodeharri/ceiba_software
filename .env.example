# ═══════════════════════════════════════════════════════════════════
# MercadoExpress — local dev env (DUMMY values, NOT for production)
# Auditoría: variables que el código REALMENTE lee.
# Archivo: .env.dev (gitignored). NO commitear.
# ═══════════════════════════════════════════════════════════════════

# ── Compose / Docker ──────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ceiba_software
LOCAL_DEV_NETWORK_NAME=ceiba_local_dev

# ── Postgres (compose) ────────────────────────────────────────────
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_CONTAINER_NAME=ceiba-postgres
POSTGRES_USER=ceiba
POSTGRES_PASSWORD=ceiba_dev
POSTGRES_DB=mercadoexpress
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=ceiba_software_pgdata
POSTGRES_HEALTHCHECK_RETRIES=20

# ── LocalStack (compose) ──────────────────────────────────────────
LOCALSTACK_IMAGE=localstack/localstack:3.4
LOCALSTACK_CONTAINER_NAME=ceiba-localstack
LOCALSTACK_HOST=localhost
LOCALSTACK_PORT=4566
LOCALSTACK_VOLUME_NAME=ceiba_software_localstack-data
LOCALSTACK_DEBUG=0
LOCALSTACK_PERSISTENCE=1
LOCALSTACK_HEALTHCHECK_INTERVAL=2s
LOCALSTACK_HEALTHCHECK_RETRIES=30
# Set trimmed per REQ-DEM-2. Override aquí solo si necesitás otros servicios.
LOCALSTACK_SERVICES=serverless,s3,sqs,sns,secretsmanager,iam,sts,cloudformation

# ── Healthchecks globales ──────────────────────────────────────────
HEALTHCHECK_INTERVAL=5s
HEALTHCHECK_TIMEOUT=30s

# ── AWS (dummy — LocalStack no valida) ────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── CDK stage ─────────────────────────────────────────────────────
STAGE=localstack

# ── Backend / Prisma (REQUERIDO) ──────────────────────────────────
DATABASE_URL=postgresql://ceiba:ceiba_dev@localhost:5432/mercadoexpress

# ── JWT (REQUERIDO, ≥32 chars) ───────────────────────────────────
JWT_SECRET=dev-only-jwt-secret-change-me-in-prod-min-32-chars
JWT_SECRET_PREVIOUS=dev-only-jwt-previous-secret-change-me-too-min-32

# ── CORS (default http://localhost:5173) ──────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── Dev server (opcional, todos tienen default) ───────────────────
PORT=3001
DEV_SERVER_MAX_BODY_BYTES=1048576
WAIT_FOR_IDLE=false
BCRYPT_COST=10

# ── Seed admin (REQUERIDO para `pnpm db:seed`) ────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ceiba.local
ADMIN_PASSWORD=admin123-change-me-in-prod

# ── E2E tests (Playwright) ────────────────────────────────────────
E2E_BASE_URL=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api/v1
# ----- Embedding provider (Phase 1: gemini only) -----
EMBEDDING_PROVIDER=gemini
# Gemini API key — local dev only. AWS uses SSM SecureString at /ceiba/${STAGE}/gemini-api-key.
GEMINI_API_KEY=
