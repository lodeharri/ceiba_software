# MercadoExpress -- root environment variables.
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Stage names align with openspec/config.yaml -> infra.stages.
# Region defaults to us-east-1 (RISK-W05 tracks prod sizing).

# Stage and region.
STAGE=dev
AWS_REGION=us-east-1

# Database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mercadoexpress

# JWT (dual-secret rotation, D6).
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-me-with-64-hex-chars
JWT_SECRET_PREVIOUS=
JWT_OVERLAP_SECONDS=900

# Admin seed (D6).
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@mercadoexpress.local
ADMIN_PASSWORD=change-me-on-first-deploy

# AI providers (env-selectable adapter, openspec/config.yaml).
OLLAMA_HOST=http://localhost:11434
GROQ_API_KEY=
OPENAI_API_KEY=

# AWS / CI.
OIDC_ROLE_ARN=
TRUSTED_PROXY_DEPTH=0

# Frontend.
VITE_API_BASE_URL=http://localhost:3000
